# Telegram
TELEGRAM_BOT_TOKEN=

# CookMyBots AI Gateway (REQUIRED)
# COOKMYBOTS_AI_ENDPOINT is a BASE URL (do NOT include /chat)
COOKMYBOTS_AI_ENDPOINT=https://api.cookmybots.com/api/ai
COOKMYBOTS_AI_KEY=

# Database (optional but recommended for persistent settings)
MONGODB_URI=

# Optional controls
AI_TIMEOUT_MS=600000
AI_MAX_RETRIES=2
CONCURRENCY=20

# Logging (optional)
LOG_LEVEL=info
